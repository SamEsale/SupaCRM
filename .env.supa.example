# =============================================================================
# SupaCRM local development environment
# Copy this file to .env.supa for local startup.
# These values are for local use only. Rotate every secret for shared or production environments.
# =============================================================================

ENV=dev
DEBUG=false
APP_BASE_URL=http://127.0.0.1:8000
APP_NAME=SupaCRM API
LOG_LEVEL=INFO

# Frontend URLs
FRONTEND_BASE_URL=http://127.0.0.1:3000
EMAIL_VERIFY_URL=http://127.0.0.1:3000/verify-email
PASSWORD_RESET_URL=http://127.0.0.1:3000/reset-password

# Multi-tenancy
TENANT_HEADER_NAME=X-Tenant-Id
REQUIRE_TENANT_HEADER=true

# Database / Cache
DATABASE_URL_ASYNC=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/supacrm
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/supacrm
DATABASE_URL_ADMIN_ASYNC=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/supacrm
DATABASE_URL_ADMIN_SYNC=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/supacrm
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/supacrm
BOOTSTRAP_API_KEY=local-bootstrap-key-change-me
REDIS_URL=redis://127.0.0.1:6379/0
RQ_HEALTHCHECK_ENABLED=false
RQ_QUEUE_NAME=default

# Auth / Security
JWT_SECRET=local-dev-jwt-secret-change-me-000000000000000000000000000000000000
REFRESH_TOKEN_SECRET=local-dev-refresh-secret-change-me-0000000000000000000000000000
JWT_ALGORITHM=HS256
JWT_ISSUER=supacrm
JWT_AUDIENCE=supacrm-api
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
TRUST_PROXY_HEADERS=true

# Storage / MinIO
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=supacrm
MINIO_USE_SSL=false

# Payments redirects
PAYMENTS_SUCCESS_URL=http://127.0.0.1:3000/payments/success
PAYMENTS_FAILURE_URL=http://127.0.0.1:3000/payments/failure

# Email
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@supacrm.local
SMTP_USE_TLS=false
SMTP_USE_SSL=false
